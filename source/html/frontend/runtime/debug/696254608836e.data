    `kcu`.`CONSTRAINT_NAME` AS `constraint_name`,
    `kcu`.`COLUMN_NAME` AS `column_name`,
    `kcu`.`REFERENCED_TABLE_NAME` AS `referenced_table_name`,
    `kcu`.`REFERENCED_COLUMN_NAME` AS `referenced_column_name`
FROM `information_schema`.`REFERENTIAL_CONSTRAINTS` AS `rc`
JOIN `information_schema`.`KEY_COLUMN_USAGE` AS `kcu` ON
    (
        `kcu`.`CONSTRAINT_CATALOG` = `rc`.`CONSTRAINT_CATALOG` OR
        (`kcu`.`CONSTRAINT_CATALOG` IS NULL AND `rc`.`CONSTRAINT_CATALOG` IS NULL)
    ) AND
    `kcu`.`CONSTRAINT_SCHEMA` = `rc`.`CONSTRAINT_SCHEMA` AND
    `kcu`.`CONSTRAINT_NAME` = `rc`.`CONSTRAINT_NAME`
WHERE `rc`.`CONSTRAINT_SCHEMA` = database() AND `kcu`.`TABLE_SCHEMA` = database()
AND `rc`.`TABLE_NAME` = 'hts_help' AND `kcu`.`TABLE_NAME` = 'hts_help'";i:1;i:80;i:2;s:21:"yii\db\Command::query";i:3;d:1768051808.713977;i:4;a:3:{i:0;a:5:{s:4:"file";s:49:"/var/www/html/frontend/components/MyComponent.php";s:4:"line";i:35;s:8:"function";s:3:"all";s:5:"class";s:18:"yii\db\ActiveQuery";s:4:"type";s:2:"->";}i:1;a:5:{s:4:"file";s:58:"/var/www/html/frontend/modules/user/views/listing/view.php";s:4:"line";i:2920;s:8:"function";s:7:"getHelp";s:5:"class";s:31:"frontend\components\MyComponent";s:4:"type";s:2:"::";}i:2;a:5:{s:4:"file";s:69:"/var/www/html/frontend/modules/user/controllers/ListingController.php";s:4:"line";i:616;s:8:"function";s:6:"render";s:5:"class";s:19:"yii\base\Controller";s:4:"type";s:2:"->";}}i:5;i:1989600;}i:428;a:6:{i:0;s:772:"SELECT
