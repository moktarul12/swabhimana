{
    "name": "yiisoft/yii2-app-advanced",
    "description": "Yii 2 Advanced Project Template (PHP 8.4)",
    "type": "project",
    "license": "BSD-3-Clause",
    "minimum-stability": "stable",
    "prefer-stable": true,

    "require": {
        "php": ">=8.4",
        "ext-mbstring": "*",
        "ext-intl": "*",
        "ext-openssl": "*",
        "ext-json": "*",

        "yiisoft/yii2": "^2.0.49",
        "yiisoft/yii2-bootstrap": "^2.0",
        "yiisoft/yii2-authclient": "^2.1",

        "firebase/php-jwt": "^6.0",
        "stripe/stripe-php": "^13.0",
        "aws/aws-sdk-php": "^3.0",

        "himiklab/yii2-recaptcha-widget": "^2.1",
        "sightengine/client-php": "^1.3",
        "stichoza/google-translate-php": "^5.0",
        "npm-asset/jquery": "^3.7",
        "yiisoft/yii2-symfonymailer": "^2.0",
        "symfony/mailer": "^6.3",
        "symfony/mime": "^6.3",
        "symfony/http-client": "^6.3"
    },

    "require-dev": {
        "yiisoft/yii2-debug": "^2.1",
        "yiisoft/yii2-gii": "^2.2",
        "yiisoft/yii2-faker": "^2.0"
    },

    "config": {
        "process-timeout": 1800,
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },

    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
